# ─── Django ────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True

# ─── Database ──────────────────────────────────────────────────────────────
# Leave empty to use the local SQLite file during development.
# Set to your Supabase Postgres URL for production:
#   postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=

# ─── Supabase Storage ──────────────────────────────────────────────────────
# Project URL  (Settings → API → Project URL)
SUPABASE_URL=https://<project-ref>.supabase.co

# Service-role key  (Settings → API → service_role secret)
# NEVER expose this key on the frontend or commit it to git.
SUPABASE_SERVICE_KEY=eyJh...

# Name of the bucket to use (must already exist in Supabase Storage)
SUPABASE_BUCKET=saikona-media

# ─── Firebase ──────────────────────────────────────────────────────────────
# Path to the service-account JSON downloaded from Firebase Console
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
